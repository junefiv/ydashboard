# 복사 후 `.env`로 저장하고 값을 채우세요. `.env`는 Git에 올리지 마세요.

# Gemini (serve_cs_dashboard.py) — 둘 중 하나만 있으면 됩니다.
GOOGLE_GENAI_API_KEY=
# GEMINI_API_KEY=
# GEMINI_MODEL_ID=gemini-flash-latest

# 원격 대시보드(GitHub Pages)가 이 서버의 /api 를 호출할 때 허용 오리진. 비우면 * (개발 편의). 운영 예: https://junefiv.github.io
# CS_DASHBOARD_CORS_ORIGIN=

# 이감(yigam.co.kr) 로그인 (yigam_*.py)
YIGAM_USERNAME=
YIGAM_PASSWORD=
